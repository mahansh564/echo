[
  {
    "$schema": "../gen/schemas/desktop-schema.json",
    "identifier": "default",
    "description": "Capability for the main window",
    "windows": ["main"],
    "permissions": [
      "core:default",
      "opener:default",
      "core:webview:allow-create-webview-window",
      "core:window:allow-create"
    ]
  },
  {
    "identifier": "terminal-popout",
    "description": "Capability for terminal popout windows",
    "windows": ["terminal-popout"],
    "permissions": [
      "core:default",
      "opener:default"
    ]
  }
]
